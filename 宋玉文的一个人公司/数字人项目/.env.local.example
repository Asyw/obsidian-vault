# Copy this file to .env.local and fill in your own values.

# Volcengine Ark Agent/Coding Plan dedicated API Key.
ARK_API_KEY=your_ark_agent_plan_dedicated_api_key
ARK_MODEL=your_ark_endpoint_or_model_id
ARK_RESPONSES_MODEL=ark-code-latest
ARK_EMBEDDING_MODEL=doubao-embedding-vision
ARK_IMAGE_MODEL=doubao-seedream-5.0-lite
ARK_VIDEO_MODEL=doubao-seedance-1.5-pro
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_TIMEOUT_SECONDS=60

# Doubao openspeech TTS voice settings. This is not the Ark model API.
ARK_TTS_VOICE_ID=your_voice_id
ARK_TTS_RESOURCE_ID=seed-icl-2.0
ARK_TTS_AUDIO_FORMAT=mp3
ARK_TTS_SAMPLE_RATE=24000
ARK_TTS_SPEED_RATIO=1.0
ARK_TTS_VOLUME_RATIO=1.0
ARK_TTS_PITCH_RATIO=1.0

# Short-video generation settings.
SHORT_VIDEO_MODE=hybrid
# Override this per request when the user specifies 16:9 or 9:16.
SHORT_VIDEO_ASPECT_RATIO=9:16
SHORT_VIDEO_RESOLUTION=1080x1920
SHORT_VIDEO_DURATION_SECONDS=30
SHORT_VIDEO_FPS=24
SHORT_VIDEO_OUTPUT_FORMAT=mp4
SHORT_VIDEO_OUTPUT_DIR=outputs/videos
SHORT_VIDEO_SUBTITLE_ENABLED=true
SHORT_VIDEO_COVER_ENABLED=true

# Doubao speech service credentials for voice clone/TTS service.
DOUBAO_SPEECH_API_KEY=your_speech_model_api_key
DOUBAO_SPEECH_APP_ID=your_speech_app_id
DOUBAO_SPEECH_ACCESS_TOKEN=your_speech_access_token
DOUBAO_SPEECH_SECRET_KEY=your_speech_secret_key
DOUBAO_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
DOUBAO_TTS_RESOURCE_ID=seed-icl-2.0
DOUBAO_TTS_UID=digital-human-project

# Volcengine OpenAPI / digital-human talking-head video settings.
VOLCENGINE_ACCESS_KEY_ID=your_volcengine_access_key_id
VOLCENGINE_SECRET_ACCESS_KEY=your_volcengine_secret_access_key
DIGITAL_HUMAN_VIDEO_MODE=talking_head
DIGITAL_HUMAN_AVATAR_ID=your_digital_human_avatar_id
DIGITAL_HUMAN_AUDIO_URL=https://example.com/narration.wav
DIGITAL_HUMAN_REQ_KEY=realman_avatar_creation_task
DIGITAL_HUMAN_API_ENDPOINT=https://visual.volcengineapi.com
DIGITAL_HUMAN_API_REGION=cn-beijing
DIGITAL_HUMAN_API_SERVICE=cv
DIGITAL_HUMAN_API_VERSION=2024-06-06
# Override this per request when the user specifies 16:9 or 9:16.
DIGITAL_HUMAN_ASPECT_RATIO=9:16
DIGITAL_HUMAN_RESOLUTION=1080x1920
DIGITAL_HUMAN_VIDEO_FORMAT=mp4
DIGITAL_HUMAN_VIDEO_CODEC=H264
DIGITAL_HUMAN_BACKGROUND=default
